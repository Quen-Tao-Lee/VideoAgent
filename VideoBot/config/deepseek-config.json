{
    "deepseek": {
        "api_base_url": "https://api.deepseek.com/v1",
        "models": {
            "chat": "deepseek-chat",
            "coder": "deepseek-coder", 
            "transcription": "whisper-1"
        },
        "settings": {
            "max_retries": 3,
            "retry_delay_ms": 1000,
            "timeout_seconds": 30,
            "max_audio_size_mb": 25
        },
        "features": {
            "audio_transcription": true,
            "content_analysis": true,
            "marketing_generation": true,
            "seo_optimization": true,
            "subtitle_optimization": true,
            "cost_monitoring": true
        },
        "output_formats": {
            "transcription": "srt",
            "analysis": "json",
            "marketing": "txt",
            "keywords": "txt",
            "subtitles": "srt"
        },
        "cost_limits": {
            "daily_limit_usd": 10.0,
            "per_video_limit_usd": 1.0,
            "warning_threshold_usd": 0.8
        },
        "content_analysis": {
            "temperature": 0.3,
            "max_tokens": 1500,
            "include_sentiment": true,
            "include_topics": true,
            "include_audience": true
        },
        "marketing_generation": {
            "temperature": 0.8,
            "max_tokens": 1000,
            "platforms": [
                "youtube",
                "tiktok", 
                "bilibili",
                "weibo",
                "douyin",
                "general"
            ]
        },
        "seo_optimization": {
            "temperature": 0.5,
            "max_tokens": 800,
            "keyword_count": {
                "primary": 8,
                "long_tail": 12,
                "topic_tags": 15
            }
        },
        "subtitle_optimization": {
            "temperature": 0.3,
            "max_tokens": 2000,
            "preserve_timing": true,
            "improve_readability": true,
            "fix_grammar": true
        }
    },
    "integration": {
        "priority": "deepseek",
        "fallback_to_openai": true,
        "enable_ai_features": true,
        "auto_generate_analysis": true,
        "auto_generate_marketing": true,
        "auto_generate_seo": true,
        "auto_optimize_subtitles": true
    },
    "logging": {
        "log_api_calls": true,
        "log_costs": true,
        "log_errors": true,
        "performance_monitoring": true
    }
}